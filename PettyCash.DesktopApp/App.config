<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <!-- ============================================================================
       App.config - Application Configuration
       Petty Cash Management System
       ============================================================================ -->

  <!-- Connection Strings -->
  <connectionStrings>
    <!--
      LOCAL (PC running SQLite locally):
    -->
    <add name="PettyCashDB"
         providerName="System.Data.SQLite"
         connectionString="Data Source=PettyCash.db;Version=3;" />

    <!--
      LAN / Remote (client PC connecting to server over network):
    <add name="PettyCashDB"
         connectionString="Server=192.168.1.100;Port=3306;Database=PettyCashDB;Uid=root;Pwd=;CharSet=utf8mb4;SslMode=None;AllowPublicKeyRetrieval=true;"
         providerName="MySql.Data.MySqlClient" />
    -->
  </connectionStrings>

  <appSettings>
    <!-- Application Info -->
    <add key="AppName" value="Petty Cash Management System" />
    <add key="AppVersion" value="1.0.0" />
    <add key="OrganizationName" value="Ceylon Electricity Board - Haliela" />

    <!-- Business Rules -->
    <add key="MonthlyLimit" value="25000" />
    <add key="SingleBillLimit" value="5000" />
    <add key="HighValueThreshold" value="3000" />
    <add key="MinDescriptionLength" value="3" />

    <!-- Session Settings -->
    <add key="SessionTimeoutMinutes" value="30" />
    <add key="MaxLoginAttempts" value="5" />

    <!-- Email Notification Settings -->
    <add key="EmailNotificationsEnabled" value="False" />
    <add key="SmtpHost" value="smtp.gmail.com" />
    <add key="SmtpPort" value="587" />
    <add key="SenderEmail" value="" />
    <add key="SenderPassword" value="" />
    <add key="AdminEmail" value="" />

    <!-- WhatsApp Notification Settings (Twilio) -->
    <add key="WhatsAppNotificationsEnabled" value="False" />
    <add key="TwilioAccountSid" value="" />
    <add key="TwilioAuthToken" value="" />
    <add key="TwilioWhatsAppNumber" value="" />
    <add key="AdminWhatsAppNumber" value="" />

    <!-- Logging -->
    <add key="EnableDetailedLogging" value="False" />
    <add key="LogFilePath" value="Logs\app.log" />
  </appSettings>

  <!-- .NET 8 target — no <startup> element needed -->

</configuration>
